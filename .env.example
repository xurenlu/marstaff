# AI Provider API Keys
QWEN_API_KEY=your_qwen_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# Optional: Other providers
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Aliyun OSS (for storing generated videos/images)
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# WebSocket node clients (?role=node) — must match configs/config.yaml gateway_node.token
MARSTAFF_NODE_TOKEN=

# Optional adapters
TELEGRAM_BOT_TOKEN=
MATRIX_BOT_USERNAME=
MATRIX_BOT_PASSWORD=
